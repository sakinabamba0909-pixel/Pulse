# ============================================================
# Pulse — Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# Supabase (get from: supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic (get from: console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Albanian Immersion App
# ============================================================

# PostgreSQL Database (for Prisma - Albanian app)
DATABASE_URL=postgresql://user:password@localhost:5432/albanian_immersion?schema=public

# OpenAI - Required for TTS audio and answer evaluation
OPENAI_API_KEY=sk-your-key-here

# AWS S3 (optional - for production audio caching)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=albanian-audio
